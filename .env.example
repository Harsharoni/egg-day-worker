# egg9000.com API key
EGG9000_API_KEY=your_api_key_here

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/eggday

# Google Sheets — IDs from the sheet URL: docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SERVICE_ACCOUNT_FILE=creds.json
SPREADSHEET_ID=your_comp_sheet_id
SCOREBOARD_WORKSHEET=Scoreboard

# Google Form responses sheet for registration (leave empty to disable sync)
REGISTRATION_SPREADSHEET_ID=
REGISTRATION_WORKSHEET=Form Responses 1

# Competition window, ISO-8601 UTC
# 15/07/2026 17:00 BST -> 16:00 UTC; 16/07/2026 18:30 BST -> 17:30 UTC
COMP_START_UTC=2026-07-15T16:00:00+00:00
COMP_END_UTC=2026-07-16T17:30:00+00:00

# Fair-factor exponent
FAIR_POWER=0.235

# Poll every 30 minutes by default; override if needed
POLL_INTERVAL_MINUTES=15

# Report image: min SE gain to include (default 1e18 = 100Q)
REPORT_MIN_GAIN=1e18
REPORT_LIMIT=50
